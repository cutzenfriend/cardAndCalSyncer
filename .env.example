# CaCs – cardAndCalSyncer. Kopieren nach .env. Alle Werte sind optional:
# Accounts/Logins richtest du im Web-UI ein. .env NIEMALS committen.

# --- Admin-Bootstrap (optional) ---------------------------------------------
# Wenn gesetzt, wird beim ersten Start ein Admin-Konto angelegt (sonst /setup im Browser).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Benachrichtigungen (optional) ------------------------------------------
# Komma-getrennte Apprise-URLs, z.B. ntfy://ntfy.sh/mein-topic,mailto://...
APPRISE_URLS=

# --- Sonstiges (optional) ---------------------------------------------------
SYNC_INTERVAL=300
LOG_LEVEL=INFO
