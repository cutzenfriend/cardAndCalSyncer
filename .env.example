# CaCs – cardAndCalSyncer. Copy to .env. All values are optional:
# accounts/logins are configured in the web UI. NEVER commit .env.

# --- Admin bootstrap (optional) ---------------------------------------------
# If set, an admin account is created on first start (otherwise /setup in the browser).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Notifications (optional) -----------------------------------------------
# Comma-separated Apprise URLs, e.g. ntfy://ntfy.sh/my-topic,mailto://...
APPRISE_URLS=

# --- Misc (optional) --------------------------------------------------------
SYNC_INTERVAL=300
LOG_LEVEL=INFO
